" General
set number
set linebreak
set showbreak=+++
set textwidth=100
set showmatch
set visualbell
 
set hlsearch
set smartcase
set ignorecase
set incsearch
syntax on
set tabstop=4
set expandtab
set shiftwidth=4

set autoindent
set shiftwidth=4
set smartindent
set smarttab
set softtabstop=4

" Advanced
set ruler
 
set undolevels=1000
set backspace=indent,eol,start

"Colors
highlight LineNr cterm=NONE ctermfg=DarkGrey ctermbg=NONE gui=NONE guifg=#666666
